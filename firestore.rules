rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidSecret(data) {
      return data.encryptedData is string && data.encryptedData.size() <= 100000 &&
             data.iv is string && data.iv.size() <= 64 &&
             data.salt is string && data.salt.size() <= 64 &&
             data.viewLimit is number && data.viewLimit >= 1 && data.viewLimit <= 999999 &&
             data.viewCount is number && data.viewCount >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidChatRoom(data) {
      return data.roomCode is string && data.roomCode.size() <= 128 &&
             data.encryptedValidator is string && data.encryptedValidator.size() <= 5000 &&
             data.iv is string && data.iv.size() <= 64 &&
             data.salt is string && data.salt.size() <= 64 &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp;
    }

    function isValidChatMessage(data) {
      return data.senderId is string && data.senderId.size() <= 128 &&
             data.encryptedText is string && data.encryptedText.size() <= 50000 &&
             data.iv is string && data.iv.size() <= 64 &&
             data.salt is string && data.salt.size() <= 64 &&
             data.timestamp is timestamp;
    }

    match /secrets/{secretId} {
      // Anyone can create a secret
      allow create: if isValidId(secretId) && 
                      isValidSecret(incoming()) && 
                      incoming().viewCount == 0 &&
                      incoming().createdAt == request.time;

      // Anyone can get a secret IF the view limit hasn't been reached
      allow get: if existing().viewCount < existing().viewLimit;

      // Allow updating ONLY the viewCount
      allow update: if isValidSecret(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['viewCount']) &&
                      incoming().viewCount == existing().viewCount + 1 &&
                      incoming().viewCount <= existing().viewLimit;
      
      allow delete: if false;
    }

    match /chatRooms/{roomId} {
      allow create: if isValidId(roomId) && isValidChatRoom(incoming()) && incoming().createdAt == request.time;
      allow get: if true;
    }

    match /chatRooms/{roomId}/messages/{messageId} {
      allow create: if isValidId(messageId) && isValidChatMessage(incoming()) && 
                      incoming().timestamp == request.time &&
                      get(/databases/$(database)/documents/chatRooms/$(roomId)).data.expiresAt > request.time;
      allow list, get: if get(/databases/$(database)/documents/chatRooms/$(roomId)).data.expiresAt > request.time;
    }
  }
}
