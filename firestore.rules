rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }

    // SHARED UTILS
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function isWithinExpiry(expiresAt) { return request.time < expiresAt; }

    // ROOMS
    match /chatRooms/{roomCode} {
      function isValidRoom(data) {
        return data.roomCode is string && data.roomCode.size() <= 12 &&
               data.encryptedValidator is string && data.encryptedValidator.size() <= 10000 &&
               data.iv is string && data.iv.size() <= 128 &&
               data.salt is string && data.salt.size() <= 128 &&
               (data.iterations == null || (data.iterations is number && data.iterations >= 1000 && data.iterations <= 1000000)) &&
               data.createdAt is timestamp &&
               data.expiresAt is timestamp;
      }

      // Anyone can create a room or get a room if they have the ID
      allow get: if true;
      allow create: if isValidRoom(incoming());
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.senderId is string && data.senderId.size() <= 64 &&
                 data.encryptedText is string && data.encryptedText.size() <= 2000000 && // 2MB for potential large file base64
                 data.iv is string && data.iv.size() <= 128 &&
                 data.salt is string && data.salt.size() <= 128 &&
                 (data.iterations == null || (data.iterations is number && data.iterations >= 1000 && data.iterations <= 1000000)) &&
                 data.timestamp is timestamp;
        }

        // Only allow reading and writing if the room hasn't expired
        // Note: get(/databases/$(database)/documents/chatRooms/$(roomCode))
        allow list, get: if isWithinExpiry(get(/databases/$(database)/documents/chatRooms/$(roomCode)).data.expiresAt);
        allow create: if isWithinExpiry(get(/databases/$(database)/documents/chatRooms/$(roomCode)).data.expiresAt) 
                        && isValidMessage(incoming());
        allow update: if isWithinExpiry(get(/databases/$(database)/documents/chatRooms/$(roomCode)).data.expiresAt)
                        && incoming().diff(resource.data).affectedKeys().hasOnly(['reactions']);
      }

      // TYPING INDICATORS
      match /typing/{userId} {
        allow read: if isWithinExpiry(get(/databases/$(database)/documents/chatRooms/$(roomCode)).data.expiresAt);
        allow write: if isWithinExpiry(get(/databases/$(database)/documents/chatRooms/$(roomCode)).data.expiresAt);
      }
    }
  }
}
