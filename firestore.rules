rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'linkUrl', 'description', 'tags', 'order'])
        && data.title is string && data.title.size() <= 200
        && data.category is string && data.category.size() <= 100
        && data.linkUrl is string && data.linkUrl.size() <= 1000
        && data.description is string && data.description.size() <= 2000
        && data.tags is list
        && data.order is number;
    }

    function isValidAbout(data) {
      return data.keys().hasAll(['badge', 'title', 'description', 'image'])
        && data.badge is string && data.badge.size() <= 100
        && data.title is string && data.title.size() <= 500
        && data.description is string && data.description.size() <= 5000
        && data.image is string && data.image.size() <= 1000;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isValidId(projectId) && isValidProject(request.resource.data);
      allow delete: if isValidId(projectId);
    }

    match /settings/about {
      allow read: if true;
      allow write: if isValidAbout(request.resource.data);
    }
  }
}
