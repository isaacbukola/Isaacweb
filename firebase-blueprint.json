{
  "entities": {
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A temporary secure chat shard.",
      "type": "object",
      "properties": {
        "roomCode": { "type": "string" },
        "encryptedValidator": { "type": "string" },
        "iv": { "type": "string" },
        "salt": { "type": "string" },
        "iterations": { "type": "number", "description": "PBKDF2 iteration count" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomCode", "encryptedValidator", "iv", "salt", "createdAt", "expiresAt"]
    },
    "TypingStatus": {
      "title": "Typing Status",
      "description": "Indicates if a user is currently typing.",
      "type": "object",
      "properties": {
        "isTyping": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["isTyping", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "An encrypted message packet.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "encryptedText": { "type": "string" },
        "iv": { "type": "string" },
        "salt": { "type": "string" },
        "iterations": { "type": "number", "description": "PBKDF2 iteration count used for this packet" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reactions": { 
          "type": "object", 
          "description": "Map of emoji to user ID lists",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        }
      },
      "required": ["senderId", "encryptedText", "iv", "salt", "timestamp"]
    }
  },
  "firestore": {
    "/chatRooms/{roomCode}": {
      "schema": "ChatRoom",
      "description": "Root room document"
    },
    "/chatRooms/{roomCode}/typing/{userId}": {
      "schema": "TypingStatus",
      "description": "Real-time typing indicator for a user"
    },
    "/chatRooms/{roomCode}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Encrypted message packets"
    }
  }
}
